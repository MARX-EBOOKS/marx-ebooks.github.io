[{"file": "MEW44-001.html", "title": "说明", "headings": [{"tag": "title", "text": "说明", "level": 1, "id": null, "filename": "MEW44-001.html"}]}, {"file": "MEW44-002.html", "title": "法国来信", "headings": [{"tag": "title", "text": "法国来信", "level": 1, "id": null, "filename": "MEW44-002.html"}, {"tag": "h3", "text": "一", "level": 3, "id": "h2-0", "filename": "MEW44-002.html"}, {"tag": "h3", "text": "二  红色共和主义光辉成就的鲜明证据！", "level": 3, "id": "h2-1", "filename": "MEW44-002.html"}, {"tag": "h3", "text": "三  时代的象征。——迫近的革命", "level": 3, "id": "h2-2", "filename": "MEW44-002.html"}, {"tag": "h3", "text": "四  选举。——红色分子的光荣胜利。——无产阶级的优势。  ——秩序党的沮丧。——对革命进行镇压和挑拨的新计划", "level": 3, "id": "h2-3", "filename": "MEW44-002.html"}, {"tag": "h3", "text": "五", "level": 3, "id": "h2-4", "filename": "MEW44-002.html"}, {"tag": "h3", "text": "六", "level": 3, "id": "h2-5", "filename": "MEW44-002.html"}, {"tag": "h3", "text": "七", "level": 3, "id": "h2-6", "filename": "MEW44-002.html"}, {"tag": "h3", "text": "八", "level": 3, "id": "h2-7", "filename": "MEW44-002.html"}]}, {"file": "MEW44-003.html", "title": "德国来信", "headings": [{"tag": "title", "text": "德国来信", "level": 1, "id": null, "filename": "MEW44-003.html"}, {"tag": "h3", "text": "一", "level": 3, "id": "h3-0", "filename": "MEW44-003.html"}, {"tag": "h3", "text": "二  关于德国暴君的有趣揭露。  ——蓄意对法国进行的战争。  ——未来的革命", "level": 3, "id": "h3-1", "filename": "MEW44-003.html"}, {"tag": "h3", "text": "三  普鲁士国王宣誓忠于宪法和“侍奉上帝！”——神圣同盟的大阴谋。  ——日益临近的对瑞士的进攻。——征服和瓜分法国的计划！", "level": 3, "id": "h3-2", "filename": "MEW44-003.html"}]}, {"file": "MEW44-004.html", "title": "卡·马克思和弗·恩格斯　启事", "headings": [{"tag": "title", "text": "卡·马克思和弗·恩格斯　启事", "level": 1, "id": null, "filename": "MEW44-004.html"}]}, {"file": "MEW44-005.html", "title": "革命的两年。1848年和1849年", "headings": [{"tag": "title", "text": "革命的两年。1848年和1849年", "level": 1, "id": null, "filename": "MEW44-005.html"}]}, {"file": "MEW44-006.html", "title": "德国来信。什列斯维希―霍尔施坦的战争", "headings": [{"tag": "title", "text": "德国来信。什列斯维希―霍尔施坦的战争", "level": 1, "id": null, "filename": "MEW44-006.html"}]}, {"file": "MEW44-007.html", "title": "*卡·马克思和弗·恩格斯《国际述评（三）》一文中有关德国的草稿", "headings": [{"tag": "title", "text": "*卡·马克思和弗·恩格斯《国际述评（三）》一文中有关德国的草稿", "level": 1, "id": null, "filename": "MEW44-007.html"}]}, {"file": "MEW44-008.html", "title": "卡·马克思和弗·恩格斯*关于社会民主主义德国流亡者救济委员会的钱款的声明草稿", "headings": [{"tag": "title", "text": "卡·马克思和弗·恩格斯*关于社会民主主义德国流亡者救济委员会的钱款的声明草稿", "level": 1, "id": null, "filename": "MEW44-008.html"}]}, {"file": "MEW44-009.html", "title": "*关于大·李嘉图《政治经济学和赋税原理》（摘录、评注、笔记）", "headings": [{"tag": "title", "text": "*关于大·李嘉图《政治经济学和赋税原理》（摘录、评注、笔记）", "level": 1, "id": null, "filename": "MEW44-009.html"}, {"tag": "h2", "text": "（大）·李嘉图。政治经济学和赋税原理。  1821年伦敦第三版（货币学说）", "level": 2, "id": "1", "filename": "MEW44-009.html"}, {"tag": "h3", "text": "（1）金银价值的变动", "level": 3, "id": "1-1", "filename": "MEW44-009.html"}, {"tag": "h3", "text": "（2）《货币价值的变动所引起的不同后果》", "level": 3, "id": "1-2", "filename": "MEW44-009.html"}, {"tag": "h3", "text": "（3）金货币与银货币及对外贸易", "level": 3, "id": "1-3", "filename": "MEW44-009.html"}, {"tag": "h3", "text": "（4）“货币只充当一种尺度，用来表示相对价值”，  表示用一种商品去换另一种商品所付出的数量", "level": 3, "id": "1-4", "filename": "MEW44-009.html"}, {"tag": "h3", "text": "（5）黄金税。（或问题：黄金生产困难的增大如何影响它的价值？）", "level": 3, "id": "1-5", "filename": "MEW44-009.html"}, {"tag": "h3", "text": "（6）货币[借贷]的利息", "level": 3, "id": "1-6", "filename": "MEW44-009.html"}, {"tag": "h3", "text": "（7）货币，输出和输入", "level": 3, "id": "1-7", "filename": "MEW44-009.html"}, {"tag": "h3", "text": "（8）论货币流通与银行。纸币。恐慌。  国家发行银行券。谁有权发行纸币：  国家还是某个贸易公司？后一种办法对贸易是否必要？黄金。", "level": 3, "id": "1-8", "filename": "MEW44-009.html"}, {"tag": "h3", "text": "（9）关于富国与穷国的黄金、谷物和劳动的相对价值", "level": 3, "id": "1-9", "filename": "MEW44-009.html"}, {"tag": "h3", "text": "*关于李嘉图对土地税观点的评注", "level": 3, "id": "1-10", "filename": "MEW44-009.html"}, {"tag": "h3", "text": "与社会地位有关的赋税", "level": 3, "id": "h9-11", "filename": "MEW44-009.html"}, {"tag": "h3", "text": "*李嘉图著作名目索引草稿", "level": 3, "id": "1-11", "filename": "MEW44-009.html"}, {"tag": "h2", "text": "（大·）李嘉图。政治经济学和赋税原理。  1821年伦敦第三版", "level": 2, "id": "2", "filename": "MEW44-009.html"}, {"tag": "h3", "text": "（Ⅰ）论价值", "level": 3, "id": "2-1", "filename": "MEW44-009.html"}, {"tag": "h3", "text": "（Ⅱ）论地租", "level": 3, "id": "2-2", "filename": "MEW44-009.html"}, {"tag": "h4", "text": "原产品税", "level": 4, "id": "h9-16", "filename": "MEW44-009.html"}, {"tag": "h4", "text": "地租（反对亚·斯密关于地租的学说）", "level": 4, "id": "h9-17", "filename": "MEW44-009.html"}, {"tag": "h4", "text": "地租（反对马尔萨斯的地租观点）", "level": 4, "id": "h9-18", "filename": "MEW44-009.html"}, {"tag": "h4", "text": "输入谷物对地租和租地农场主利润的影响", "level": 4, "id": "h9-19", "filename": "MEW44-009.html"}, {"tag": "h4", "text": "自由输入谷物对租地农场主的利润和资本的影响", "level": 4, "id": "h9-20", "filename": "MEW44-009.html"}, {"tag": "h4", "text": "不是由土地的相对肥力产生的第二部分地租", "level": 4, "id": "h9-21", "filename": "MEW44-009.html"}, {"tag": "h3", "text": "（Ⅲ）论自然价格与市场价格", "level": 3, "id": "2-3", "filename": "MEW44-009.html"}, {"tag": "h4", "text": "价值（自然价格）与财富的区别", "level": 4, "id": "h9-23", "filename": "MEW44-009.html"}, {"tag": "h4", "text": "论需求和供给对价格的影响", "level": 4, "id": "h9-24", "filename": "MEW44-009.html"}, {"tag": "h4", "text": "决定所生产的商品量的不是它们的生产费用，  即它们的实际价值，而是它们的市场价格", "level": 4, "id": "h9-25", "filename": "MEW44-009.html"}, {"tag": "h4", "text": "农业和机器的改良所起的贬值作用", "level": 4, "id": "h9-26", "filename": "MEW44-009.html"}, {"tag": "h4", "text": "谷物价格不是其他商品价格的调节者", "level": 4, "id": "h9-27", "filename": "MEW44-009.html"}, {"tag": "h4", "text": "对外贸易和交换价值", "level": 4, "id": "h9-28", "filename": "MEW44-009.html"}, {"tag": "h4", "text": "各国的交换价值的规定", "level": 4, "id": "h9-29", "filename": "MEW44-009.html"}, {"tag": "h4", "text": "殖民地贸易对价格的影响", "level": 4, "id": "h9-30", "filename": "MEW44-009.html"}, {"tag": "h4", "text": "供求对交换价值的影响", "level": 4, "id": "h9-31", "filename": "MEW44-009.html"}, {"tag": "h3", "text": "（Ⅳ）论工资", "level": 3, "id": "2-4", "filename": "MEW44-009.html"}, {"tag": "h4", "text": "工资和花在商品生产上的劳动量之间的差别", "level": 4, "id": "h9-33", "filename": "MEW44-009.html"}, {"tag": "h4", "text": "资本增加对工资的市场价格和[劳动的]自然[价格]的影响", "level": 4, "id": "h9-34", "filename": "MEW44-009.html"}, {"tag": "h4", "text": "劳动的自然价格的变动", "level": 4, "id": "h9-35", "filename": "MEW44-009.html"}, {"tag": "h4", "text": "工资和地租", "level": 4, "id": "h9-36", "filename": "MEW44-009.html"}, {"tag": "h4", "text": "劳动自然价格的上涨和商品的货币价格", "level": 4, "id": "h9-37", "filename": "MEW44-009.html"}, {"tag": "h4", "text": "人口与工资", "level": 4, "id": "h9-38", "filename": "MEW44-009.html"}, {"tag": "h4", "text": "原产品价格对工资的影响", "level": 4, "id": "h9-39", "filename": "MEW44-009.html"}, {"tag": "h4", "text": "机器对工资的影响", "level": 4, "id": "h9-40", "filename": "MEW44-009.html"}, {"tag": "h4", "text": "工资税", "level": 4, "id": "h9-41", "filename": "MEW44-009.html"}, {"tag": "h4", "text": "再论利润和工资的关系", "level": 4, "id": "h9-42", "filename": "MEW44-009.html"}, {"tag": "h3", "text": "（Ⅴ）论利润", "level": 3, "id": "2-5", "filename": "MEW44-009.html"}, {"tag": "h4", "text": "利润率的不断变动。  产品价格在资本家和工人之间的分配", "level": 4, "id": "h9-44", "filename": "MEW44-009.html"}, {"tag": "h4", "text": "利润和工资的关系", "level": 4, "id": "h9-45", "filename": "MEW44-009.html"}, {"tag": "h4", "text": "资本的积累", "level": 4, "id": "h9-46", "filename": "MEW44-009.html"}, {"tag": "h4", "text": "贸易对利润的影响", "level": 4, "id": "h9-47", "filename": "MEW44-009.html"}, {"tag": "h4", "text": "贸易进程中的突然变化", "level": 4, "id": "h9-48", "filename": "MEW44-009.html"}, {"tag": "h4", "text": "积累对利润和利息的影响", "level": 4, "id": "h9-49", "filename": "MEW44-009.html"}, {"tag": "h4", "text": "论总收入和纯收入", "level": 4, "id": "h9-50", "filename": "MEW44-009.html"}, {"tag": "h4", "text": "利润税", "level": 4, "id": "h9-51", "filename": "MEW44-009.html"}, {"tag": "h4", "text": "机器和赋税。对利润的影响", "level": 4, "id": "h9-52", "filename": "MEW44-009.html"}, {"tag": "h4", "text": "原产品以外的其他商品税", "level": 4, "id": "h9-53", "filename": "MEW44-009.html"}, {