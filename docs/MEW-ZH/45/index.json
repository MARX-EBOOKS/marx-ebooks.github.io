[{"file": "MEW45-001.html", "title": "说明", "headings": [{"tag": "title", "text": "说明", "level": 1, "id": null, "filename": "MEW45-001.html"}]}, {"file": "MEW45-002.html", "title": "弗·恩格斯　*瑞典和丹麦旅游札记", "headings": [{"tag": "title", "text": "弗·恩格斯　*瑞典和丹麦旅游札记", "level": 1, "id": null, "filename": "MEW45-002.html"}]}, {"file": "MEW45-003.html", "title": "卡·马克思。*从美国革命到1801年合并的爱尔兰", "headings": [{"tag": "title", "text": "卡·马克思。*从美国革命到1801年合并的爱尔兰", "level": 1, "id": null, "filename": "MEW45-003.html"}, {"tag": "h3", "text": "Ⅰ.1778年至1782年。独立", "level": 3, "id": "h3-0", "filename": "MEW45-003.html"}, {"tag": "h4", "text": "（Ａ）1782年以前的爱尔兰议会", "level": 4, "id": "h3-1", "filename": "MEW45-003.html"}, {"tag": "h4", "text": "波伊宁兹法", "level": 4, "id": "h3-2", "filename": "MEW45-003.html"}, {"tag": "h4", "text": "乔治一世在位第六年法规", "level": 4, "id": "h3-3", "filename": "MEW45-003.html"}, {"tag": "h4", "text": "高潮开始前十八世纪爱尔兰议会的一般性质", "level": 4, "id": "h3-4", "filename": "MEW45-003.html"}, {"tag": "h4", "text": "（Ｂ）美国独立战争对爱尔兰影响的最初结果，立法独立以前", "level": 4, "id": "h3-5", "filename": "MEW45-003.html"}, {"tag": "h4", "text": "（ａ）天主教徒惩治法典的放宽", "level": 4, "id": "h3-6", "filename": "MEW45-003.html"}, {"tag": "h4", "text": "（ｂ）组织志愿兵。争取自由贸易的运动。英国方面最初的让步", "level": 4, "id": "h3-7", "filename": "MEW45-003.html"}, {"tag": "h4", "text": "（Ｃ）爱尔兰立法独立的宣言", "level": 4, "id": "h3-8", "filename": "MEW45-003.html"}, {"tag": "h3", "text": "Ⅱ.1782年（宣布独立之后）至1795年", "level": 3, "id": "h3-9", "filename": "MEW45-003.html"}, {"tag": "h4", "text": "（Ａ）1782年至1783年。（改革法案的破产和志愿兵的大失败）", "level": 4, "id": "h3-10", "filename": "MEW45-003.html"}, {"tag": "h4", "text": "（Ｂ）1783年底至1791年。（“爱尔兰人联合会”的建立）", "level": 4, "id": "h3-11", "filename": "MEW45-003.html"}, {"tag": "h4", "text": "（1）反什一税等等的骚乱。在爱尔兰实行英国反骚乱法令", "level": 4, "id": "h3-12", "filename": "MEW45-003.html"}, {"tag": "h4", "text": "（2）都柏林市长的选举（1790年）", "level": 4, "id": "h3-13", "filename": "MEW45-003.html"}, {"tag": "h3", "text": "（Ｃ）1791年10月至1795年4月初（菲茨威廉勋爵被召回，由坎登勋