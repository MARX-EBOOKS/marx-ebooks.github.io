": "h6", "text": "Remark: Immediate Identity of Inner and Outer", "level": 6, "id": "HGL219", "filename": "HGSL21.html"}, {"tag": "h4", "text": "Transition to Actuality", "level": 4, "id": "HGL2110", "filename": "HGSL21.html"}]}, {"file": "HGSL22.html", "title": "Section Three: Actuality", "headings": [{"tag": "h2", "text": "Section Three: Actuality", "level": 2, "id": "HGL221", "filename": "HGSL22.html"}]}, {"file": "HGSL23.html", "title": "Chapter 1 The Absolute", "headings": [{"tag": "h3", "text": "Chapter 1 The Absolute", "level": 3, "id": "HGL231", "filename": "HGSL23.html"}, {"tag": "h4", "text": "A. THE EXPOSITION OF THE ABSOLUTE", "level": 4, "id": "HGL232", "filename": "HGSL23.html"}, {"tag": "h4", "text": "B. THE ABSOLUTE ATTRIBUTE", "level": 4, "id": "HGL233", "filename": "HGSL23.html"}, {"tag": "h4", "text": "C. THE MODE OF THE ABSOLUTE", "level": 4, "id": "HGL234", "filename": "HGSL23.html"}, {"tag": "h6", "text": "Remark: The Philosophy of Spinoza and Leibniz", "level": 6, "id": "HGL235", "filename": "HGSL23.html"}]}, {"file": "HGSL24.html", "title": "Introduction", "headings": [{"tag": "h1", "text": "Introduction", "level": 1, "id": "HGL241", "filename": "HGSL24.html"}, {"tag": "h3", "text": "General Notion of Logic", "level": 3, "id": "HGL242", "filename": "HGSL24.html"}]}, {"file": "HGSL25.html", "title": "Chapter 2 Actuality", "headings": [{"tag": "h3", "text": "Chapter 2 Actuality", "level": 3, "id": "HGL251", "filename": "HGSL25.html"}, {"tag": "h4", "text": "A. CONTINGENCY, OR FORMAL ACTUALITY, POSSIBILITY, AND NECESSITY", "level": 4, "id": "HGL252", "filename": "HGSL25.html"}, {"tag": "h4", "text": "B. RELATIVE NECESSITY, OR REAL ACTUALITY, POSSIBILITY, AND NECESSITY", "level": 4, "id": "HGL253", "filename": "HGSL25.html"}, {"tag": "h4", "text": "C. ABSOLUTE NECESSITY", "level": 4, "id": "HGL254", "filename": "HGSL25.html"}]}, {"file": "HGSL26.html", "title": "Chapter 3 The Absolute Relation", "headings": [{"tag": "h3", "text": "Chapter 3 The A